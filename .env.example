# --- Better Auth -----------------------------------------------------------
# 32 文字以上のランダム文字列。`openssl rand -base64 32` で生成
BETTER_AUTH_SECRET=
# サーバ側がアプリのオリジンとして使う URL
BETTER_AUTH_URL=http://localhost:3000

# --- Turso (libSQL) --------------------------------------------------------
# 未設定なら file:./local.db のローカル SQLite を使う
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Sign-up control -------------------------------------------------------
# "true" で新規登録を許可。未設定または他の値は新規登録を無効にする
NEXT_PUBLIC_SIGNUP_ENABLED=true
